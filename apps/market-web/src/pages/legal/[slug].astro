---
import { getEntry, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { substitute } from "../../lib/legal-secrets";

/**
 * Server-mode dynamic route. `getStaticPaths` is for static builds only;
 * since `astro.config.mjs` sets `output: "server"`, we resolve the entry
 * directly from `Astro.params.slug` at request time. If the slug is
 * unknown, we 404 — same behaviour the static version had implicitly.
 *
 * PR 4.5 (secrets-refactor): the body of the markdown file is processed
 * by `remark-substitute-legal-placeholders` (registered in
 * astro.config.mjs) which replaces `{{TOKEN}}` markers with SST Secret
 * values at AST level. Frontmatter values (`title`, `summary`,
 * `contact_email`) are substituted HERE at request time so the same
 * SST Secret values flow into the surrounding layout.
 */
const slug = Astro.params.slug ?? "";
const entry = (await getEntry("legal", slug)) as CollectionEntry<"legal"> | undefined;
if (!entry) {
  return new Response("Not found", { status: 404 });
}
const { Content } = await entry.render();

const renderedTitle = substitute(entry.data.title);
const renderedSummary = entry.data.summary ? substitute(entry.data.summary) : undefined;
const renderedContactEmail = substitute(entry.data.contact_email);
const formattedDate = entry.data.effective_date.toLocaleDateString("es-CO", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${renderedTitle} — Opita Market`} description={renderedSummary}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8 pb-6 border-b border-slate-200">
      <p class="text-xs uppercase tracking-wider text-sky-700 font-semibold mb-2">
        Documento legal · Versión {entry.data.version}
      </p>
      <h1 class="text-3xl font-bold text-slate-900 mb-2">
        {renderedTitle}
      </h1>
      <p class="text-sm text-slate-500">
        Vigente desde el <time datetime={entry.data.effective_date.toISOString()}>{formattedDate}</time>
      </p>
      {renderedSummary && (
        <p class="mt-4 text-base text-slate-600 italic">
          {renderedSummary}
        </p>
      )}
    </header>

    <div class="legal-prose">
      <Content />
    </div>

    <aside class="mt-12 pt-6 border-t border-slate-200 bg-slate-50 rounded-lg p-6">
      <h2 class="text-base font-semibold text-slate-900 mb-2">
        ¿Necesita contactar al DPO?
      </h2>
      <p class="text-sm text-slate-600 mb-3">
        Para ejercer sus derechos como titular (conocer, actualizar,
        rectificar, suprimir) escriba a:
      </p>
      <a
        href={`mailto:${renderedContactEmail}`}
        class="inline-block bg-sky-700 text-white text-sm font-medium px-4 py-2 rounded hover:bg-sky-800"
      >
        {renderedContactEmail}
      </a>
      <p class="mt-3 text-xs text-slate-500">
        SLA de respuesta: 15 días hábiles. Autoridad de supervisión:
        Superintendencia de Industria y Comercio (SIC).
      </p>
    </aside>
  </article>
</BaseLayout>
