---
/**
 * Vertical page — Opita Barber
 * /demo/barber
 */
import DemoLayout from "../../../layouts/DemoLayout.astro";
import Container from "../../../components/demo/Container.astro";
import Section from "../../../components/demo/Section.astro";
import Badge from "../../../components/demo/Badge.astro";
import Button from "../../../components/demo/Button.astro";
import Card from "../../../components/demo/Card.astro";
import BusinessCard from "../../../components/demo/BusinessCard.astro";
import { VERTICALES, getRandomNegociosByVertical } from "../../../lib/demo-data";

const vertical = VERTICALES.barber;
const negocios = getRandomNegociosByVertical("barber", 5);
---

<DemoLayout title={`${vertical.nombre} — Barberías del Huila con precios publicados`}>
  <Section tone="default" size="none" class="relative !py-0 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/demo/verticals/barber.png"
        alt=""
        aria-hidden="true"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/85 to-white/20"></div>
    </div>
    <Container class="relative py-20 lg:py-28">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <a href="/demo" class="inline-flex items-center gap-1 text-sm text-ink-600 hover:text-brand-700 mb-4">
            ← Volver a Opita Market
          </a>
          <Badge variant="sky">{vertical.pruebaSocial}</Badge>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-ink-900 mt-4 mb-4 tracking-tight leading-[1.05]">
            <span class="text-5xl sm:text-6xl mr-2">{vertical.emoji}</span>
            {vertical.nombre}
          </h1>
          <p class="text-xl text-sky-800 font-medium mb-4">{vertical.subtitulo}</p>
          <p class="text-lg text-ink-700 leading-relaxed mb-8 max-w-2xl">{vertical.descripcion}</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <Button variant="primary" size="lg">{vertical.ctaPrimario}</Button>
            <Button variant="outline" size="lg">Ver servicios y precios</Button>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="brand" size="lg">
    <Container>
      <Card tone="brand">
        <h3 class="font-bold text-ink-900 mb-3 text-xl">¿Por qué Opita Barber?</h3>
        <ul class="space-y-2 text-sm text-ink-700 sm:grid sm:grid-cols-2 sm:gap-x-6">
          <li class="flex gap-2"><span>✂️</span><span>Precios publicados antes de llegar</span></li>
          <li class="flex gap-2"><span>📍</span><span>Barberías cerca de ti con horarios reales</span></li>
          <li class="flex gap-2"><span>⭐</span><span>Reseñas verificadas de otros clientes</span></li>
          <li class="flex gap-2"><span>💬</span><span>Reservá por WhatsApp, sin llamadas</span></li>
          <li class="flex gap-2 sm:col-span-2"><span>💰</span><span>Pagá con Opita Saldo en muchas barberías</span></li>
        </ul>
      </Card>
    </Container>
  </Section>

  <Section tone="muted" size="md">
    <Container>
      <h2 class="text-2xl font-bold text-ink-900 mb-6 text-center">Servicios más buscados</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {vertical.categorias.map((cat) => (
          <a href="#" class="block p-4 rounded-xl bg-surface-elevated border border-border hover:border-brand-300 hover:shadow-sm transition-all text-center">
            <div class="text-sm font-semibold text-ink-900">{cat}</div>
          </a>
        ))}
      </div>
    </Container>
  </Section>

  <Section tone="default" size="lg">
    <Container>
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-3xl font-bold text-ink-900 mb-2">Barberías cerca de ti</h2>
          <p class="text-ink-600">Recomendadas según ubicación, reseñas y verificación.</p>
        </div>
        <Button variant="ghost" href="#">Ver todas →</Button>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {negocios.map((n) => <BusinessCard negocio={n} showPrice />)}
      </div>
    </Container>
  </Section>

  <Section tone="warm" size="md">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-ink-900 mb-3">
          ¿Sos barbero y querés aparecer aquí?
        </h2>
        <p class="text-ink-600 mb-6">Reclamá tu perfil gratis. Mostrá tus servicios, fotos y precios.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <Button variant="primary">Reclamar mi barbería gratis</Button>
        </div>
      </div>
    </Container>
  </Section>
</DemoLayout>