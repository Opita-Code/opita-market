---
/**
 * Vertical page — Opita Foods
 * /demo/foods
 */
import DemoLayout from "../../../layouts/DemoLayout.astro";
import Container from "../../../components/demo/Container.astro";
import Section from "../../../components/demo/Section.astro";
import Badge from "../../../components/demo/Badge.astro";
import Button from "../../../components/demo/Button.astro";
import Card from "../../../components/demo/Card.astro";
import BusinessCard from "../../../components/demo/BusinessCard.astro";
import PriceBoardRow from "../../../components/demo/PriceBoardRow.astro";
import { VERTICALES, getRandomNegociosByVertical, PRICE_BOARD } from "../../../lib/demo-data";

const vertical = VERTICALES.foods;
const negocios = getRandomNegociosByVertical("foods", 5);
const foodsPriceBoard = PRICE_BOARD.filter((p) =>
  ["Frutas", "Tubérculos", "Cárnicos", "Lácteos", "Café"].includes(p.categoria),
);
---

<DemoLayout title={`${vertical.nombre} — Restaurantes y productos frescos del Huila`}>
  {/* Hero with full-bleed image */}
  <Section tone="default" size="none" class="relative !py-0 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/demo/verticals/foods.png"
        alt=""
        aria-hidden="true"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/85 to-white/20"></div>
    </div>
    <Container class="relative py-20 lg:py-28">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <a href="/demo" class="inline-flex items-center gap-1 text-sm text-ink-600 hover:text-brand-700 mb-4">
            ← Volver a Opita Market
          </a>
          <Badge variant="brand">{vertical.pruebaSocial}</Badge>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-ink-900 mt-4 mb-4 tracking-tight leading-[1.05]">
            <span class="text-5xl sm:text-6xl mr-2">{vertical.emoji}</span>
            {vertical.nombre}
          </h1>
          <p class="text-xl text-brand-800 font-medium mb-4">{vertical.subtitulo}</p>
          <p class="text-lg text-ink-700 leading-relaxed mb-8 max-w-2xl">{vertical.descripcion}</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <Button variant="primary" size="lg">{vertical.ctaPrimario}</Button>
            <Button variant="outline" size="lg" href="#price-board">Ver precios mayoristas</Button>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="brand" size="lg">
    <Container>
      <div class="grid sm:grid-cols-2 gap-5">
        <Card tone="brand">
          <Badge variant="brand" size="xs">B2C · Consumidor final</Badge>
          <h3 class="font-bold text-ink-900 mt-2 mb-1 text-xl">Pedí a restaurantes del Huila</h3>
          <p class="text-sm text-ink-700 mb-4">
            Menú, precios, horarios. Pide por WhatsApp o paga con Opita Saldo.
          </p>
          <Button variant="primary" size="md">Ver restaurantes</Button>
        </Card>
        <Card tone="accent">
          <Badge variant="accent" size="xs">B2B · Como Frubana</Badge>
          <h3 class="font-bold text-ink-900 mt-2 mb-1 text-xl">Compra al por mayor para tu negocio</h3>
          <p class="text-sm text-ink-700 mb-4">
            Precios mayoristas de frutas, verduras, cárnicos y café, actualizados.
          </p>
          <Button variant="accent" size="md" href="#price-board">Ver price-board</Button>
        </Card>
      </div>
    </Container>
  </Section>

  {/* Categorías */}
  <Section tone="muted" size="md">
    <Container>
      <h2 class="text-2xl font-bold text-ink-900 mb-6 text-center">¿Qué buscás hoy?</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {vertical.categorias.map((cat) => (
          <a
            href="#"
            class="block p-4 rounded-xl bg-surface-elevated border border-border hover:border-brand-300 hover:shadow-sm transition-all text-center"
          >
            <div class="text-sm font-semibold text-ink-900">{cat}</div>
          </a>
        ))}
      </div>
    </Container>
  </Section>

  {/* Price board B2B */}
  <Section tone="default" size="lg" id="price-board">
    <Container>
      <div class="mb-8 max-w-2xl">
        <Badge variant="accent">B2B · Mayorista</Badge>
        <h2 class="text-3xl font-bold text-ink-900 mt-3 mb-3">
          Precios al por mayor — actualizados hoy
        </h2>
        <p class="text-ink-600">
          Para restaurantes, tiendas y revendedores. Cada precio lo publican los productores y mayoristas
          del Huila. No más llamadas para verificar.
        </p>
      </div>

      <Card padding="none" class="overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-ink-50 border-b border-border">
              <tr class="text-xs font-semibold text-ink-700 uppercase tracking-wide">
                <th class="py-3 px-4 text-left">Producto</th>
                <th class="py-3 px-4 text-right">Mínimo</th>
                <th class="py-3 px-4 text-right">Máximo</th>
                <th class="py-3 px-4 text-right">Promedio</th>
                <th class="py-3 px-4 text-center">Tendencia</th>
                <th class="py-3 px-4 text-center hidden sm:table-cell">Locales</th>
              </tr>
            </thead>
            <tbody>
              {foodsPriceBoard.map((entry) => <PriceBoardRow entry={entry} />)}
            </tbody>
          </table>
        </div>
      </Card>
    </Container>
  </Section>

  {/* Featured businesses */}
  <Section tone="muted" size="lg">
    <Container>
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-3xl font-bold text-ink-900 mb-2">Negocios destacados</h2>
          <p class="text-ink-600">Los más recomendados esta semana según tu ubicación y reseñas.</p>
        </div>
        <Button variant="ghost" href="#">Ver todos →</Button>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {negocios.map((n) => <BusinessCard negocio={n} showPrice />)}
      </div>
    </Container>
  </Section>

  {/* CTA final */}
  <Section tone="warm" size="md">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-ink-900 mb-3">
          ¿Tenés un restaurante o vendés productos del Huila?
        </h2>
        <p class="text-ink-600 mb-6">
          Reclamá tu perfil gratis. Publicá tu menú o tus precios mayoristas.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <Button variant="primary">Reclamar mi negocio gratis</Button>
          <Button variant="ghost" href="/demo">Ver otros verticales</Button>
        </div>
      </div>
    </Container>
  </Section>
</DemoLayout>