---
/**
 * Vertical page — Opita Hogar
 * /demo/hogar
 */
import DemoLayout from "../../../layouts/DemoLayout.astro";
import Container from "../../../components/demo/Container.astro";
import Section from "../../../components/demo/Section.astro";
import Badge from "../../../components/demo/Badge.astro";
import Button from "../../../components/demo/Button.astro";
import Card from "../../../components/demo/Card.astro";
import BusinessCard from "../../../components/demo/BusinessCard.astro";
import { VERTICALES, getRandomNegociosByVertical } from "../../../lib/demo-data";

const vertical = VERTICALES.hogar;
const negocios = getRandomNegociosByVertical("hogar", 5);
---

<DemoLayout title={`${vertical.nombre} — Profesionales del hogar en el Huila`}>
  <Section tone="default" size="none" class="relative !py-0 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/demo/verticals/hogar.png"
        alt=""
        aria-hidden="true"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/85 to-white/20"></div>
    </div>
    <Container class="relative py-20 lg:py-28">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <a href="/demo" class="inline-flex items-center gap-1 text-sm text-ink-600 hover:text-brand-700 mb-4">
            ← Volver a Opita Market
          </a>
          <Badge variant="default">{vertical.pruebaSocial}</Badge>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-ink-900 mt-4 mb-4 tracking-tight leading-[1.05]">
            <span class="text-5xl sm:text-6xl mr-2">{vertical.emoji}</span>
            {vertical.nombre}
          </h1>
          <p class="text-xl text-ink-700 font-medium mb-4">{vertical.subtitulo}</p>
          <p class="text-lg text-ink-700 leading-relaxed mb-8 max-w-2xl">{vertical.descripcion}</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <Button variant="primary" size="lg">{vertical.ctaPrimario}</Button>
            <Button variant="outline" size="lg">Pedir emergencia 24/7</Button>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="brand" size="lg">
    <Container>
      <Card>
        <h3 class="font-bold text-ink-900 mb-3 text-xl">Profesionales verificados</h3>
        <p class="text-sm text-ink-700 mb-4 max-w-2xl">
          Cada profesional pasa por validación de identidad y antecedentes.
          Reseñas reales de clientes verificados.
        </p>
        <div class="grid sm:grid-cols-2 gap-2 mt-4">
          <div class="flex items-center gap-2 text-sm"><span class="text-accent-700">✓</span><span>Identidad validada</span></div>
          <div class="flex items-center gap-2 text-sm"><span class="text-accent-700">✓</span><span>Reseñas de clientes reales</span></div>
          <div class="flex items-center gap-2 text-sm"><span class="text-accent-700">✓</span><span>Garantía de servicio</span></div>
          <div class="flex items-center gap-2 text-sm"><span class="text-accent-700">✓</span><span>Pagos seguros con Opita Saldo</span></div>
        </div>
      </Card>
    </Container>
  </Section>

  <Section tone="muted" size="md">
    <Container>
      <h2 class="text-2xl font-bold text-ink-900 mb-6 text-center">¿Qué necesitás hoy?</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {vertical.categorias.map((cat) => (
          <a href="#" class="block p-4 rounded-xl bg-surface-elevated border border-border hover:border-brand-300 hover:shadow-sm transition-all text-center">
            <div class="text-sm font-semibold text-ink-900">{cat}</div>
          </a>
        ))}
      </div>
    </Container>
  </Section>

  <Section tone="default" size="lg">
    <Container>
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-3xl font-bold text-ink-900 mb-2">Profesionales cerca de ti</h2>
          <p class="text-ink-600">Fontaneros, electricistas, albañiles, jardineros con reseñas.</p>
        </div>
        <Button variant="ghost" href="#">Ver todos →</Button>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {negocios.map((n) => <BusinessCard negocio={n} showPrice />)}
      </div>
    </Container>
  </Section>

  <Section tone="warm" size="md">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-ink-900 mb-3">¿Sos profesional del hogar?</h2>
        <p class="text-ink-600 mb-6">Reclamá tu perfil y empezá a recibir clientes en el Huila.</p>
        <Button variant="primary">Reclamar mi perfil gratis</Button>
      </div>
    </Container>
  </Section>
</DemoLayout>