---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Opita Market — Marketplace del Huila">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-slate-900 mb-4">
      Opita Market
    </h1>
    <p class="text-lg text-slate-600 max-w-2xl">
      Marketplace multi-vertical del Huila. Conectamos establecimentos
      locales con consumidores de toda Colombia, respetando la
      <a href="/legal/ptd" class="text-sky-700 hover:underline">
        Política de Tratamiento de Datos
      </a> y el
      <a href="/legal/aviso" class="text-sky-700 hover:underline">
        Aviso de Privacidad
      </a> vigentes.
    </p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="border border-slate-200 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-2">
          Datos públicos
        </h2>
        <p class="text-sm text-slate-600">
          Solo publicamos información comercial verificable del
          establecimiento (razón social, NIT, horarios, fotos).
        </p>
      </div>
      <div class="border border-slate-200 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-2">
          Datos del representante
        </h2>
        <p class="text-sm text-slate-600">
          Los datos personales del representante legal requieren
          consentimiento explícito antes de ser almacenados.
        </p>
      </div>
      <div class="border border-slate-200 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-2">
          Tus derechos
        </h2>
        <p class="text-sm text-slate-600">
          Conocer, actualizar, rectificar o suprimir tus datos.
          Respondemos en máximo 15 días hábiles.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>