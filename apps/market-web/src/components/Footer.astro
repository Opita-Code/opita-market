---
/**
 * Site-wide footer. Per Ley 1581/2012 + Decreto 1377/2013 + colombia-habeas-data skill:
 *   - PTD + Aviso de Privacidad links MUST be visible on every page (footer).
 *   - DPO contact section is required.
 *
 * PR 4.5 (secrets-refactor): all personal data shown in the footer
 * (razón social, NIT, dirección, representante legal, email público)
 * is read from SST Secrets at render time via
 * `src/lib/legal-secrets.ts`. NEVER hardcode these values here —
 * re-run `scripts/setup-secrets.sh` to rotate them.
 */
import { substitute } from "../lib/legal-secrets";

const year = new Date().getFullYear();

// Pre-substitute every string that needs SST Secret values so the
// template stays declarative.
const razonSocial = substitute("{{RAZON_SOCIAL}}");
const nit = substitute("{{NIT}}");
const direccion = substitute("{{DIRECCION}}");
const repLegal = substitute("{{REP_LEGAL}}");
const emailPublico = substitute("{{EMAIL_PUBLICO}}");
const copyrightLine = substitute(
  "&copy; {{RAZON_SOCIAL}} — Todos los derechos reservados.",
);
const legalLine = substitute(
  "NIT {{NIT}} · {{DIRECCION}} · Representante legal: {{REP_LEGAL}}",
);
---

<footer class="border-t border-slate-200 bg-slate-50 py-10 mt-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wide mb-3">
          {razonSocial}
        </h3>
        <p class="text-sm text-slate-600 leading-relaxed">
          Marketplace multi-vertical del Huila y Colombia. Conectamos
          establecimentos con consumidores respetando la Ley 1581/2012 de
          Habeas Data.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wide mb-3">
          Tratamiento de datos
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="/legal/ptd"
              class="text-sky-700 hover:text-sky-900 hover:underline"
              data-testid="footer-link-ptd"
            >
              Política de Tratamiento de Datos (PTD)
            </a>
          </li>
          <li>
            <a
              href="/legal/aviso"
              class="text-sky-700 hover:text-sky-900 hover:underline"
              data-testid="footer-link-aviso"
            >
              Aviso de Privacidad
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wide mb-3">
          Oficial de Protección de Datos (DPO)
        </h3>
        <p class="text-sm text-slate-600">
          Para ejercer sus derechos como titular (conocer, actualizar,
          rectificar, suprimir) contáctenos en:
        </p>
        <ul class="mt-2 space-y-1 text-sm">
          <li>
            <a
              href={`mailto:${emailPublico}`}
              class="text-sky-700 hover:text-sky-900 hover:underline"
            >
              {emailPublico}
            </a>
          </li>
          <li class="text-slate-600">{direccion}</li>
          <li class="text-slate-500 italic">SLA: 15 días hábiles</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-8 pt-6 border-t border-slate-200 text-xs text-slate-500 flex flex-col sm:flex-row justify-between gap-2"
    >
      <p set:html={copyrightLine.replace(/&copy;/g, `&copy; ${year}`)} />
      <p>{legalLine}</p>
    </div>
  </div>
</footer>
