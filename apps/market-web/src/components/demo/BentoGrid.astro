---
/**
 * BentoGrid + BentoCard — premium feature grid (Stripe/Linear style).
 *
 * Usage:
 *   <BentoGrid>
 *     <BentoCard span="lg" tone="brand">...</BentoCard>
 *     <BentoCard span="md" tone="accent">...</BentoCard>
 *     <BentoCard span="md">...</BentoCard>
 *   </BentoGrid>
 */
interface Props {
  class?: string;
  cols?: 3 | 4;
}

const { class: className = "", cols = 4 } = Astro.props;
---

<div
  class:list={[
    "grid gap-4 lg:gap-6",
    cols === 4 ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" : "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3",
    className,
  ]}
>
  <slot />
</div>