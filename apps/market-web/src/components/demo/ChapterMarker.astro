---
/**
 * ChapterMarker — section divider with chapter number + title.
 *
 * Usage:
 *   <ChapterMarker number="04" title="El algoritmo" />
 */
interface Props {
  number: string;
  title: string;
  subtitle?: string;
  tone?: "light" | "dark" | "warm";
  class?: string;
}

const { number, title, subtitle, tone = "light", class: className = "" } = Astro.props;

const toneMap = {
  light: "border-ink-200 bg-background text-ink-900",
  dark: "border-ink-800 bg-ink-950 text-ink-50",
  warm: "border-brand-200 bg-gradient-to-r from-brand-50 via-background to-accent-50 text-ink-900",
};
---

<div class:list={["py-12 sm:py-16 border-y", toneMap[tone], className]} data-reveal>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-6">
    <div class="flex-shrink-0">
      <div class:list={["text-6xl sm:text-7xl font-black tabular-nums leading-none", tone === "dark" ? "text-gradient-cool" : "text-gradient-warm"]}>
        {number}
      </div>
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-xs font-bold uppercase tracking-widest opacity-70 mb-1">Capítulo</div>
      <h2 class:list={["text-2xl sm:text-3xl lg:text-4xl font-black leading-tight tracking-tight"]}>
        {title}
      </h2>
      {subtitle && (
        <p class="mt-2 text-sm sm:text-base leading-relaxed opacity-80 max-w-2xl">
          {subtitle}
        </p>
      )}
    </div>
  </div>
</div>