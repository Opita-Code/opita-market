---
/**
 * BusinessCard — listing card for a DemoNegocio.
 *
 * Usage:
 *   <BusinessCard negocio={negocio} />
 *   <BusinessCard negocio={negocio} compact />
 */
import { formatCOP, tierLabel, type DemoNegocio } from "../../lib/demo-data";
import Badge from "./Badge.astro";
import RatingStars from "./RatingStars.astro";

interface Props {
  negocio: DemoNegocio;
  compact?: boolean;
  showPrice?: boolean;
}

const { negocio, compact = false, showPrice = false } = Astro.props;

// Pick cover gradient (no images yet — color-coded by vertical)
const gradientByVertical: Record<DemoNegocio["vertical"], string> = {
  foods: "from-brand-200 via-brand-100 to-accent-100",
  barber: "from-sky-200 via-sky-100 to-ink-100",
  beauty: "from-accent-200 via-accent-100 to-brand-100",
  hogar: "from-[oklch(0.92_0.06_65)] via-[oklch(0.95_0.04_65)] to-brand-100",
};

const initial = negocio.nombre.charAt(0);
const gradient = gradientByVertical[negocio.vertical];

const cheapestProduct = showPrice
  ? negocio.productos_destacados
      .filter((p) => p.precio_cop > 0)
      .sort((a, b) => a.precio_cop - b.precio_cop)[0]
  : null;

const verticalEmoji: Record<DemoNegocio["vertical"], string> = {
  foods: "🍲",
  barber: "💈",
  beauty: "💄",
  hogar: "🏠",
};
---

<article
  class:list={[
    "group block rounded-xl bg-surface-elevated border border-border hover:border-brand-300 hover:shadow-md transition-all duration-200 overflow-hidden",
    compact ? "" : "",
  ]}
>
  <a href={`/demo/lobby/${negocio.slug}`} class="block">
    {/* Cover */}
    <div class:list={["relative aspect-[16/9] bg-gradient-to-br", gradient]}>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-6xl opacity-30 group-hover:opacity-50 transition-opacity">
          {verticalEmoji[negocio.vertical]}
        </span>
      </div>
      <div class="absolute top-3 left-3 flex flex-wrap gap-1">
        {negocio.tier === "premium" && (
          <Badge variant="brand" size="sm">⭐ Premium</Badge>
        )}
        {negocio.verificado && (
          <Badge variant="success" size="sm">✓ Verificado</Badge>
        )}
      </div>
      <div class="absolute top-3 right-3">
        <span class="inline-flex items-center gap-1 rounded-full bg-white/90 backdrop-blur-sm text-ink-900 text-xs font-medium px-2 py-0.5">
          {verticalEmoji[negocio.vertical]} {negocio.ciudad}
        </span>
      </div>
    </div>

    {/* Body */}
    <div class="p-5 space-y-3">
      <div>
        <h3 class="text-lg font-semibold text-ink-900 leading-tight line-clamp-1">
          {negocio.nombre}
        </h3>
        <p class="mt-1 text-sm text-ink-600 line-clamp-2 leading-relaxed">
          {negocio.tagline}
        </p>
      </div>

      <div class="flex items-center justify-between">
        <RatingStars rating={negocio.rating} count={negocio.reviews_count} />
      </div>

      <div class="flex flex-wrap gap-1">
        {negocio.categorias_tags.slice(0, 3).map((tag) => (
          <Badge variant="outline" size="xs">{tag}</Badge>
        ))}
      </div>

      {showPrice && cheapestProduct && (
        <div class="pt-3 border-t border-border">
          <p class="text-xs text-ink-500">Desde</p>
          <p class="text-lg font-bold text-ink-900">
            {formatCOP(cheapestProduct.precio_cop)}
            <span class="text-sm font-normal text-ink-500 ml-1">
              / {cheapestProduct.unidad}
            </span>
          </p>
        </div>
      )}

      {!compact && (
        <div class="flex items-center gap-2 pt-2 text-xs text-ink-500">
          <span>Actualizado {negocio.precio_actualizado}</span>
          {negocio.acepta_saldo && (
            <>
              <span>·</span>
              <span class="text-accent-700 font-medium">💰 Acepta Saldo</span>
            </>
          )}
        </div>
      )}
    </div>
  </a>
</article>