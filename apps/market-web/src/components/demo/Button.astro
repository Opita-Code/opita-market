---
/**
 * Button — primary action trigger.
 *
 * Usage:
 *   <Button href="/demo/foods">Explorar Opita Foods</Button>
 *   <Button variant="secondary">Cancelar</Button>
 *   <Button variant="ghost" size="sm">Ver más</Button>
 */
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost" | "accent" | "outline";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  class: className = "",
  ariaLabel,
} = Astro.props;

const variantMap: Record<NonNullable<Props["variant"]>, string> = {
  primary:
    "bg-brand-600 text-white hover:bg-brand-700 active:bg-brand-800 shadow-sm hover:shadow",
  secondary:
    "bg-ink-900 text-white hover:bg-ink-800 active:bg-ink-700",
  ghost:
    "bg-transparent text-brand-700 hover:bg-brand-50 active:bg-brand-100",
  accent:
    "bg-accent-600 text-white hover:bg-accent-700 active:bg-accent-800 shadow-sm hover:shadow",
  outline:
    "bg-transparent text-ink-900 border-2 border-ink-200 hover:border-ink-300 hover:bg-ink-50",
};

const sizeMap: Record<NonNullable<Props["size"]>, string> = {
  sm: "h-9 px-3 text-sm rounded-md gap-1.5",
  md: "h-11 px-5 text-base rounded-lg gap-2",
  lg: "h-13 px-7 text-lg rounded-xl gap-2.5",
};

const baseCls =
  "inline-flex items-center justify-center font-semibold transition-all duration-200 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 disabled:opacity-50 disabled:cursor-not-allowed";

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  aria-label={ariaLabel}
  class:list={[baseCls, variantMap[variant], sizeMap[size], className]}
>
  <slot />
</Tag>