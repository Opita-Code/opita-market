---
/**
 * Timeline — vertical roadmap with milestones.
 *
 * Usage:
 *   <Timeline items={[
 *     { date: "Q1 2026", title: "Compliance foundation", status: "done" },
 *     { date: "Q3 2026", title: "Investor demo", status: "current" },
 *     ...
 *   ]} />
 */
interface TimelineItem {
  date: string;
  title: string;
  description?: string;
  status: "done" | "current" | "upcoming";
  tag?: string;
}

interface Props {
  items: TimelineItem[];
  tone?: "light" | "dark";
  class?: string;
}

const { items, tone = "light", class: className = "" } = Astro.props;

const toneColor: Record<NonNullable<Props["tone"]>, string> = {
  light: "text-ink-900",
  dark: "text-ink-50",
};
---

<ol class:list={["relative space-y-8", className]}>
  {/* Vertical line */}
  <div
    class="absolute left-[15px] top-2 bottom-2 w-0.5 bg-gradient-to-b from-brand-300 via-accent-300 to-transparent"
    aria-hidden="true"
  ></div>

  {items.map((item, i) => (
    <li class="relative pl-12 animate-fade-up" style={`animation-delay: ${i * 100}ms`}>
      {/* Dot */}
      <span
        class:list={[
          "absolute left-0 top-1.5 w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold ring-4 ring-background",
          item.status === "done" && "bg-accent-500 text-white",
          item.status === "current" && "bg-brand-500 text-white animate-pulse-soft",
          item.status === "upcoming" && "bg-ink-200 text-ink-600",
        ]}
        aria-hidden="true"
      >
        {item.status === "done" ? "✓" : item.status === "current" ? "●" : i + 1}
      </span>

      {/* Content */}
      <div>
        <div class="flex flex-wrap items-center gap-2 mb-1">
          <span
            class:list={[
              "inline-block px-2 py-0.5 rounded-full text-xs font-semibold",
              item.status === "done" && "bg-accent-100 text-accent-800",
              item.status === "current" && "bg-brand-100 text-brand-800",
              item.status === "upcoming" && "bg-ink-100 text-ink-600",
            ]}
          >
            {item.date}
          </span>
          {item.tag && (
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-ink-100 text-ink-700">
              {item.tag}
            </span>
          )}
        </div>
        <h3 class:list={["text-lg font-bold leading-tight", toneColor[tone]]}>{item.title}</h3>
        {item.description && (
          <p class:list={["mt-1 text-sm leading-relaxed", tone === "light" ? "text-ink-600" : "text-ink-300"]}>
            {item.description}
          </p>
        )}
      </div>
    </li>
  ))}
</ol>