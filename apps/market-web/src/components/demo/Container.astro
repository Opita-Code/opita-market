---
/**
 * Container — semantic max-width wrapper with responsive padding.
 * Pairs with web-visual-quality skill (Container query pattern).
 *
 * Usage:
 *   <Container>{children}</Container>
 *   <Container size="sm">{children}</Container>
 *   <Container as="section">{children}</Container>
 */
interface Props {
  size?: "sm" | "md" | "lg" | "xl" | "2xl" | "full";
  as?: string;
  class?: string;
}

const { size = "xl", as: Tag = "div", class: className = "" } = Astro.props;

const sizeMap: Record<NonNullable<Props["size"]>, string> = {
  sm: "max-w-2xl",
  md: "max-w-3xl",
  lg: "max-w-5xl",
  xl: "max-w-7xl",
  "2xl": "max-w-[88rem]",
  full: "max-w-none",
};
---

<Tag class:list={["mx-auto w-full px-4 sm:px-6 lg:px-8", sizeMap[size], className]}>
  <slot />
</Tag>